<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pin_bg">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/please_enter_pin"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/pinContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <ImageView
            android:id="@+id/pin1"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_margin="8dp"
            android:contentDescription="PIN 1"
            android:src="@drawable/bg_pin_circle_empty" />

        <ImageView
            android:id="@+id/pin2"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_margin="8dp"
            android:contentDescription="PIN 2"
            android:src="@drawable/bg_pin_circle_empty" />

        <ImageView
            android:id="@+id/pin3"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_margin="8dp"
            android:contentDescription="PIN 3"
            android:src="@drawable/bg_pin_circle_empty" />

        <ImageView
            android:id="@+id/pin4"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_margin="8dp"
            android:contentDescription="PIN 4"
            android:src="@drawable/bg_pin_circle_empty" />

        <ImageButton
            android:id="@+id/btnBackspace"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@color/pin_key_bg"
            android:contentDescription="@string/backspace"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_backspace"
            app:tint="@color/white" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/keypadContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:background="@color/white"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/btnSwitchToNfc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pinContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn1"
                style="@style/PinKeyStyle"
                android:layout_margin="0.25dp"
                android:text="1" />

            <Button
                android:id="@+id/btn2"
                style="@style/PinKeyStyle"
                android:layout_margin="0.25dp"
                android:text="2" />

            <Button
                android:id="@+id/btn3"
                style="@style/PinKeyStyle"
                android:layout_margin="0.25dp"
                android:text="3" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn4"
                style="@style/PinKeyStyle"
                android:layout_margin="0.25dp"
                android:text="4" />

            <Button
                android:id="@+id/btn5"
                style="@style/PinKeyStyle"
                android:layout_margin="0.25dp"
                android:text="5" />

            <Button
                android:id="@+id/btn6"
                style="@style/PinKeyStyle"
                android:layout_margin="0.25dp"
                android:text="6" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row3"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn7"
                style="@style/PinKeyStyle"
                android:layout_margin="0.25dp"
                android:text="7" />

            <Button
                android:id="@+id/btn8"
                style="@style/PinKeyStyle"
                android:layout_margin="0.25dp"
                android:text="8" />

            <Button
                android:id="@+id/btn9"
                style="@style/PinKeyStyle"
                android:layout_margin="0.25dp"
                android:text="9" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="0.25dp"
                android:layout_weight="1"
                android:background="@color/pin_bg" />

            <Button
                android:id="@+id/btn0"
                style="@style/PinKeyStyle"
                android:layout_margin="0.25dp"
                android:text="0" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="0.25dp"
                android:layout_weight="1"
                android:background="@color/pin_bg" />
        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSwitchToNfc"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/tap_nfc_card"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        app:icon="@drawable/ic_nfc_scan"
        app:iconSize="56dp"
        app:iconPadding="16dp"
        app:iconTint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>